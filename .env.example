# Eval-Runner Konfiguration (lokal, Ebene 2).
#
# Kopiere diese Datei nach  .env  und trage deine Werte ein. Die .env ist
# gitignored und wird von `npm run eval` automatisch gelesen. Reihenfolge:
#   CLI-Flag  >  echte Umgebung  >  .env  >  Vorgabe
# Fehlt die .env, ist das kein Fehler — dann gelten Flags/echte Umgebung.
#
# Hinweis: hier KEIN `export` davor (das ist nur für die Shell). Anführungs-
# zeichen um Werte sind optional.

EVAL_PROVIDER=anthropic          # anthropic | mistral
EVAL_PIPELINE_MODEL=
EVAL_JUDGE_MODEL=

# Key zum gewählten Provider — nur der jeweils genutzte muss gesetzt sein:
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
